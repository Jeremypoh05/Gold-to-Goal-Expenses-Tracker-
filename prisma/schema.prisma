// Honey — Phase 8 data model.
// Generator + datasource follow Prisma 7 conventions (driver adapter, no url here).
// The connection is supplied at runtime by the Neon adapter (src/lib/db.ts) and by
// prisma.config.ts for the CLI. See docs/phase-08-database.md.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Enums ─────────────────────────────────────────────────────
// Mirror the literal unions in src/types/expense.ts so the DB and TS agree.

enum Category {
  food
  shop
  ent
  trans
  health
  bills
  family
  other
}

enum Currency {
  SGD
  USD
  MYR
  CNY
}

/// How an expense was created. A "voice log" is NOT a separate record —
/// it's an Expense with source = voice plus the voice metadata below.
enum ExpenseSource {
  manual
  voice
}

enum VoiceStatus {
  confirmed
  edited
  reparsed
}

// ── Models ────────────────────────────────────────────────────

/// One row per signed-in person. `id` is the Clerk user id (e.g. "user_2ab…").
/// Holds the Income-page settings so they're per-user, not global constants.
model User {
  id            String   @id // Clerk userId from auth()
  email         String?
  name          String?
  currency      Currency @default(SGD) // preferred display currency

  // Income page (was SAMPLE_INCOME + the goal constants)
  // DEPRECATED (Phase 9): monthlySalary/grossSalary/deductions moved to the
  // time-aware SalaryPeriod model so salary can start mid-year and change over
  // time. Columns kept (not dropped) so the init migration can backfill the
  // first period from them; reads now go through SalaryPeriod. Safe to drop in a
  // later cleanup migration once no code references them.
  monthlySalary Decimal  @default(0) @db.Decimal(12, 2) // take-home — DEPRECATED, see SalaryPeriod
  savingsGoal   Decimal  @default(0) @db.Decimal(12, 2)
  saved         Decimal  @default(0) @db.Decimal(12, 2)
  monthlyBudget Decimal  @default(0) @db.Decimal(12, 2) // ADDED (Phase 8.1): dashboard spend budget

  // DEPRECATED (Phase 9): per-period now (see SalaryPeriod).
  grossSalary   Decimal  @default(0) @db.Decimal(12, 2)
  deductions    Decimal  @default(0) @db.Decimal(12, 2) // CPF / other deductions
  payDay        Int      @default(25) // day of month — still per-user (rarely changes)
  payFrequency  String   @default("Monthly")

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  expenses       Expense[]
  bonuses        Bonus[]
  salaryPeriods  SalaryPeriod[]
  incomeSources  IncomeSource[]
  fixedExpenses  FixedExpense[]
  monthCloses    MonthClose[]
  chatSessions   ChatSession[]
  preferences    UserPreference[]
  aiUsageLogs    AiUsageLog[]
}

/// ADDED (AI Assistant · Slice 1): a persisted assistant conversation. Messages
/// survive across visits so the chat panel / assistant page can restore history.
model ChatSession {
  id        Int           @id @default(autoincrement())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String? // auto-set from the first user message; user-renameable
  pinned    Boolean       @default(false) // ADDED (Slice 1 polish): pinned chats sort first
  /// ADDED (Slice 3c): "chat" | "quick". A quick-mic session starts as "quick" (hidden
  /// from the History list — it's a throwaway voice log, not a browsable conversation)
  /// and is promoted to "chat" the moment the user taps "Continue in assistant".
  source    String        @default("chat")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]

  @@index([userId, updatedAt])
}

/// ADDED (AI Assistant · Slice 1): one chat turn. Display text is stored; tool
/// calls/results stay transient per turn (the agent re-reads live data each time).
/// CHANGED (Slice 2b-part-2): `data` optionally holds this turn's WRITE proposals
/// + their resolved OUTCOME (confirmed / cancelled / pending), so the confirmation
/// cards AND a permanent "what you did here" status survive reloads/navigation.
model ChatMessage {
  id        Int         @id @default(autoincrement())
  sessionId Int
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String // "user" | "assistant"
  content   String
  data      Json? // { proposals: (Proposal & { outcome, resultSummary?, resolvedAt? })[] }
  createdAt DateTime    @default(now())

  @@index([sessionId])
}

/// ADDED (AI Assistant · Slice 1): lightweight preference store the agent reads
/// (get_preferences) so suggestions can respect what the user values (e.g.
/// "gaming makes me happy — don't nag"). Writes (set_preference) land in Slice 2.
model UserPreference {
  id        Int      @id @default(autoincrement())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  key       String
  value     String
  updatedAt DateTime @updatedAt

  @@unique([userId, key])
  @@index([userId])
}

/// ADDED (cost tracking): one row per completed Anthropic API call, so real
/// per-user token spend can be measured instead of guessed — the foundation for
/// subscription-plan quotas / usage-based billing / spend alerts once this becomes
/// a paid product. `feature` distinguishes the call sites (assistant chat vs voice
/// parse vs AI-suggest) since they have very different cost profiles. Token counts
/// come straight off `response.usage` — cache reads/writes are broken out because
/// they're priced very differently (~0.1x / ~1.25x normal input) from plain input.
model AiUsageLog {
  id                Int      @id @default(autoincrement())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  feature           String   // "assistant_chat" | "assistant_fast_path" | "assistant_fast_path_mini" | "voice_parse" | "voice_edit" | "ai_suggest_category" | "ai_suggest_fixed_meta"
  model             String   // e.g. "claude-sonnet-5", "claude-haiku-4-5"
  inputTokens       Int      @default(0)
  outputTokens      Int      @default(0)
  cacheReadTokens   Int      @default(0)
  cacheWriteTokens  Int      @default(0)
  createdAt         DateTime @default(now())

  @@index([userId, createdAt])
  @@index([feature, createdAt])
}

/// ADDED (Module 5): a per-month hard close. The mere existence of a row for
/// (userId, year, month) means that month is locked — no expense can be
/// created/edited/deleted (manual or voice) with a spentAt falling in it until
/// the row is removed (reopened). Scope is expenses only; income (salary/
/// bonuses/other income sources) is NOT locked by this.
model MonthClose {
  id       Int      @id @default(autoincrement())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  year     Int
  month    Int // 1–12
  closedAt DateTime @default(now())

  @@unique([userId, year, month])
  @@index([userId])
}

/// ADDED (Module 4): user-defined fixed/recurring expenses (rent, transport, 家用…).
/// Each auto-generates a real Expense row on its due day, from its start month
/// forward — NO retroactive backfill. `lastGenYear/Month` is a forward-only
/// watermark of the last month materialized, so deleting/skipping a generated row
/// never causes it to reappear. `category` drives the branded hue tile; `emoji` is
/// the glyph (AI-suggested via Claude Haiku when configured, else a local map).
model FixedExpense {
  id           Int       @id @default(autoincrement())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  label        String
  note         String?   // optional detail, e.g. "electric + phone bill"
  emoji        String    @default("📌")
  category     Category  @default(bills)
  amount       Decimal   @db.Decimal(12, 2)
  currency     Currency  @default(SGD)
  dueDay       Int       @default(1) // 1–31, clamped to the month's length

  startYear    Int
  startMonth   Int       // 1–12; first month it can generate
  endYear      Int?
  endMonth     Int?      // null = ongoing
  active       Boolean   @default(true)

  // Forward-only generation watermark (last month an Expense was created for).
  lastGenYear  Int?
  lastGenMonth Int?

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  expenses     Expense[]

  @@index([userId])
}

/// ADDED (Phase 9): time-aware salary. One row per "this salary, effective from
/// this month onward". The active salary for any calendar month is the latest
/// period whose (effectiveYear, effectiveMonth) is <= that month. Periods have no
/// end date — each runs until the next one begins; the latest runs indefinitely.
/// This models a mid-year start (no period before the start month = 0 income there)
/// and any number of raises. gross/deductions ride along with each period.
model SalaryPeriod {
  id             Int      @id @default(autoincrement())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  effectiveYear  Int      // e.g. 2026
  effectiveMonth Int      // 1–12; period takes effect on the 1st of this month
  monthlySalary  Decimal  @db.Decimal(12, 2) // take-home for this period
  grossSalary    Decimal  @default(0) @db.Decimal(12, 2)
  deductions     Decimal  @default(0) @db.Decimal(12, 2) // CPF / other
  label          String?  // "Joined", "Raise", "Promotion"…

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, effectiveYear, effectiveMonth]) // one salary change per month
  @@index([userId])
}

/// ADDED (Phase 9): custom recurring income beyond salary — freelance/side gigs,
/// investment income, rental, etc. Each source contributes `monthlyAmount` to every
/// month on or after (effectiveYear, effectiveMonth) while `active`. Like SalaryPeriod
/// it's effective-dated (no end date) but each row is an independent ongoing stream,
/// not a timeline of one value. `emoji` is a user-picked glyph for the card.
model IncomeSource {
  id             Int      @id @default(autoincrement())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  label          String   // "Freelance", "Dividends", "Rental"…
  emoji          String   @default("💰")
  monthlyAmount  Decimal  @db.Decimal(12, 2)
  effectiveYear  Int      // recurring: contributes from here on. one-off: just this month.
  effectiveMonth Int      // 1–12
  // CHANGED (Phase 9): recurring streams can STOP at a month (interval end) so raises
  // are modeled as "old ends Mar" + "new starts Apr" without erasing past months.
  // null end = ongoing. Ignored for one-off (recurring=false).
  endYear        Int?
  endMonth       Int?
  recurring      Boolean  @default(true) // true = every month in [start,end]; false = that single month only
  active         Boolean  @default(true) // hard exclude (rare); the normal "it stopped" is an end date

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
}

/// The ledger. Voice logs live here too (source = voice).
model Expense {
  id          Int           @id @default(autoincrement())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  spentAt     DateTime // full timestamp — replaces the mock's day-of-month + "HH:MM"
  category    Category
  amount      Decimal       @db.Decimal(12, 2)
  currency    Currency      @default(SGD)
  note        String
  // ADDED (Tags module): persistent free-form tags on an expense (max 5, enforced
  // in the server action + client). Normalized lowercase, no leading '#'. Postgres
  // text[] scalar list; defaults to empty so existing rows read as untagged.
  tags        String[]      @default([])
  fixed       Boolean       @default(false) // recurring fixed expense (rent, utilities…)

  source      ExpenseSource @default(manual)
  // ADDED (Module 4): link back to the FixedExpense that generated this row (if any).
  fixedSourceId Int?
  fixedSource   FixedExpense? @relation(fields: [fixedSourceId], references: [id], onDelete: SetNull)
  // Voice metadata — populated only when source = voice
  transcript  String?
  lang        String? // "zh+en" | "en" | "Singlish" …
  voiceStatus VoiceStatus?

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([userId, spentAt])
  @@index([userId, category])
}

/// Bonuses for the Income page (was IncomeInfo.bonuses[]).
/// CHANGED (Phase 9): bonuses are now year-scoped so past years stay accurate.
/// The @default(2026) exists only to backfill pre-existing rows in the migration —
/// new bonuses always carry the year the user selected.
model Bonus {
  id     Int     @id @default(autoincrement())
  userId String
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  year   Int     @default(2026)
  month  Int // 1–12
  amount Decimal @db.Decimal(12, 2)
  label  String

  @@index([userId, year])
}
