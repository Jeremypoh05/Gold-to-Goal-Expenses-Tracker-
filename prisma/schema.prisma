// Honey — Phase 8 data model.
// Generator + datasource follow Prisma 7 conventions (driver adapter, no url here).
// The connection is supplied at runtime by the Neon adapter (src/lib/db.ts) and by
// prisma.config.ts for the CLI. See docs/phase-08-database.md.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Enums ─────────────────────────────────────────────────────
// Mirror the literal unions in src/types/expense.ts so the DB and TS agree.

enum Category {
  food
  shop
  ent
  trans
  health
  bills
  other
}

enum Currency {
  SGD
  USD
  MYR
  CNY
}

/// How an expense was created. A "voice log" is NOT a separate record —
/// it's an Expense with source = voice plus the voice metadata below.
enum ExpenseSource {
  manual
  voice
}

enum VoiceStatus {
  confirmed
  edited
  reparsed
}

// ── Models ────────────────────────────────────────────────────

/// One row per signed-in person. `id` is the Clerk user id (e.g. "user_2ab…").
/// Holds the Income-page settings so they're per-user, not global constants.
model User {
  id            String   @id // Clerk userId from auth()
  email         String?
  name          String?
  currency      Currency @default(SGD) // preferred display currency

  // Income page (was SAMPLE_INCOME + the goal constants)
  // DEPRECATED (Phase 9): monthlySalary/grossSalary/deductions moved to the
  // time-aware SalaryPeriod model so salary can start mid-year and change over
  // time. Columns kept (not dropped) so the init migration can backfill the
  // first period from them; reads now go through SalaryPeriod. Safe to drop in a
  // later cleanup migration once no code references them.
  monthlySalary Decimal  @default(0) @db.Decimal(12, 2) // take-home — DEPRECATED, see SalaryPeriod
  savingsGoal   Decimal  @default(0) @db.Decimal(12, 2)
  saved         Decimal  @default(0) @db.Decimal(12, 2)
  monthlyBudget Decimal  @default(0) @db.Decimal(12, 2) // ADDED (Phase 8.1): dashboard spend budget

  // DEPRECATED (Phase 9): per-period now (see SalaryPeriod).
  grossSalary   Decimal  @default(0) @db.Decimal(12, 2)
  deductions    Decimal  @default(0) @db.Decimal(12, 2) // CPF / other deductions
  payDay        Int      @default(25) // day of month — still per-user (rarely changes)
  payFrequency  String   @default("Monthly")

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  expenses      Expense[]
  bonuses       Bonus[]
  salaryPeriods SalaryPeriod[]
  incomeSources IncomeSource[]
}

/// ADDED (Phase 9): time-aware salary. One row per "this salary, effective from
/// this month onward". The active salary for any calendar month is the latest
/// period whose (effectiveYear, effectiveMonth) is <= that month. Periods have no
/// end date — each runs until the next one begins; the latest runs indefinitely.
/// This models a mid-year start (no period before the start month = 0 income there)
/// and any number of raises. gross/deductions ride along with each period.
model SalaryPeriod {
  id             Int      @id @default(autoincrement())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  effectiveYear  Int      // e.g. 2026
  effectiveMonth Int      // 1–12; period takes effect on the 1st of this month
  monthlySalary  Decimal  @db.Decimal(12, 2) // take-home for this period
  grossSalary    Decimal  @default(0) @db.Decimal(12, 2)
  deductions     Decimal  @default(0) @db.Decimal(12, 2) // CPF / other
  label          String?  // "Joined", "Raise", "Promotion"…

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, effectiveYear, effectiveMonth]) // one salary change per month
  @@index([userId])
}

/// ADDED (Phase 9): custom recurring income beyond salary — freelance/side gigs,
/// investment income, rental, etc. Each source contributes `monthlyAmount` to every
/// month on or after (effectiveYear, effectiveMonth) while `active`. Like SalaryPeriod
/// it's effective-dated (no end date) but each row is an independent ongoing stream,
/// not a timeline of one value. `emoji` is a user-picked glyph for the card.
model IncomeSource {
  id             Int      @id @default(autoincrement())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  label          String   // "Freelance", "Dividends", "Rental"…
  emoji          String   @default("💰")
  monthlyAmount  Decimal  @db.Decimal(12, 2)
  effectiveYear  Int      // recurring: contributes from here on. one-off: just this month.
  effectiveMonth Int      // 1–12
  // CHANGED (Phase 9): recurring streams can STOP at a month (interval end) so raises
  // are modeled as "old ends Mar" + "new starts Apr" without erasing past months.
  // null end = ongoing. Ignored for one-off (recurring=false).
  endYear        Int?
  endMonth       Int?
  recurring      Boolean  @default(true) // true = every month in [start,end]; false = that single month only
  active         Boolean  @default(true) // hard exclude (rare); the normal "it stopped" is an end date

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
}

/// The ledger. Voice logs live here too (source = voice).
model Expense {
  id          Int           @id @default(autoincrement())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  spentAt     DateTime // full timestamp — replaces the mock's day-of-month + "HH:MM"
  category    Category
  amount      Decimal       @db.Decimal(12, 2)
  currency    Currency      @default(SGD)
  note        String
  fixed       Boolean       @default(false) // recurring fixed expense (rent, utilities…)

  source      ExpenseSource @default(manual)
  // Voice metadata — populated only when source = voice
  transcript  String?
  lang        String? // "zh+en" | "en" | "Singlish" …
  voiceStatus VoiceStatus?

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([userId, spentAt])
  @@index([userId, category])
}

/// Bonuses for the Income page (was IncomeInfo.bonuses[]).
/// CHANGED (Phase 9): bonuses are now year-scoped so past years stay accurate.
/// The @default(2026) exists only to backfill pre-existing rows in the migration —
/// new bonuses always carry the year the user selected.
model Bonus {
  id     Int     @id @default(autoincrement())
  userId String
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  year   Int     @default(2026)
  month  Int // 1–12
  amount Decimal @db.Decimal(12, 2)
  label  String

  @@index([userId, year])
}
